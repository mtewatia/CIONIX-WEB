# EmailJS Configuration
# Sign up at: https://www.emailjs.com/
# Get your Service ID, Template ID, and Public Key from the EmailJS dashboard

# Your EmailJS Service ID (e.g., service_xxxxxxxxxx)
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Your EmailJS Template ID (e.g., template_xxxxxxxxxx)
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# Your EmailJS Public Key (e.g., xxxxxxxxxxxxxxxxxxx)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Admin email address where contact form submissions will be sent
VITE_ADMIN_EMAIL=hello@cionix.com

# Direct backend API URL (frontend fetch endpoint)
VITE_CONTACT_API_URL=http://localhost:4000/api/contact

# Hostinger SMTP credentials (backend server uses these)
HOSTINGER_SMTP_HOST=smtp.hostinger.com
HOSTINGER_SMTP_PORT=587
HOSTINGER_SMTP_SECURE=false
HOSTINGER_SMTP_USER=your-email@yourdomain.com
HOSTINGER_SMTP_PASS=your-email-password

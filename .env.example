# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# Admin email address where contact form submissions will be sent
VITE_ADMIN_EMAIL=contact@cionixinnovations.com

# Backend API URL for contact form submissions
VITE_CONTACT_API_URL=https://your-live-domain.com/api/contact

# ============================================
# BACKEND ENVIRONMENT VARIABLES (Server)
# ============================================

# Hostinger SMTP Configuration
HOSTINGER_SMTP_HOST=smtp.hostinger.com
HOSTINGER_SMTP_PORT=587
HOSTINGER_SMTP_SECURE=false
HOSTINGER_SMTP_USER=contact@cionixinnovations.com
HOSTINGER_SMTP_PASS=YOUR_HOSTINGER_EMAIL_PASSWORD_HERE

# Server Port
PORT=4000

